# =============================================================================
# paper-toolkit-mcp 环境配置 / Environment Configuration
# =============================================================================
# 复制此文件为 .env 并填入你需要的值
# Copy this file to .env and fill in the values you need.
#
# 所有数据源无需 API key 即可使用，可选 key 可提升速率限制或扩大覆盖范围
# All sources work without API keys. Optional keys improve rate limits or coverage.
#
# 格式 / Format: paper_toolkit_mcp_<NAME>=<VALUE>
# =============================================================================

# --- 通用可选 Key / General Optional Keys ---

# Semantic Scholar API Key（提升速率限制 / improves rate limits）
# 获取方式 / How to get: https://www.semanticscholar.org/product/api#api-key
paper_toolkit_mcp_SEMANTIC_SCHOLAR_API_KEY=

# CORE API Key（开放学术搜索 / open access academic search）
# 获取方式 / How to get: https://core.ac.uk/documentation/api
paper_toolkit_mcp_CORE_API_KEY=

# Unpaywall 邮箱（免费获取开放获取 PDF / get open access PDFs for free）
# 仅需邮箱即可，无需注册 / just email, no registration needed
paper_toolkit_mcp_UNPAYWALL_EMAIL=

# DOAJ API Key（开放获取期刊目录 / Directory of Open Access Journals）
# 获取方式 / How to get: https://doaj.org/api
paper_toolkit_mcp_DOAJ_API_KEY=

# Zenodo Access Token（开放数据仓库 / open data repository）
# 获取方式 / How to get: https://zenodo.org/account/settings/applications/
paper_toolkit_mcp_ZENODO_ACCESS_TOKEN=

# Google Scholar 代理 URL（用于绕过反爬 / proxy for bypassing anti-scraping）
# 格式 / Format: http://host:port 或 socks5://host:port
paper_toolkit_mcp_GOOGLE_SCHOLAR_PROXY_URL=

# --- 可选提供商 Key / Optional Provider Keys ---

# OpenAIRE API Key（欧洲开放科学基础设施 / European open science infrastructure）
# 获取方式 / How to get: https://develop.openaire.eu/
paper_toolkit_mcp_OPENAIRE_API_KEY=

# CiteSeerX API Key（计算机科学文献 / computer science literature）
paper_toolkit_mcp_CITESEERX_API_KEY=

# IEEE Xplore API Key（电气电子工程文献 / electrical engineering literature）
# 获取方式 / How to get: https://developer.ieee.org/
paper_toolkit_mcp_IEEE_API_KEY=

# ACM Digital Library API Key（计算机科学文献 / computer science literature）
# 获取方式 / How to get: https://developers.acm.org/
paper_toolkit_mcp_ACM_API_KEY=

# --- 高级配置 / Advanced Configuration ---

# 自定义 .env 文件路径 / Override env file path if needed
# paper_toolkit_mcp_ENV_FILE=/absolute/path/to/.env

# 向后兼容：不带前缀的旧格式仍然支持
# Backward compatibility: legacy names without paper_toolkit_mcp_ prefix are still supported.
